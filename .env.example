PORT=3000
# PGLITE_DIR unset = in-memory. Set to a path for file-backed dev DB, e.g. .pglite
PGLITE_DIR=.pglite
# Contact-request SLA sweep interval in ms (default 15 min)
SWEEP_INTERVAL_MS=900000
# Surepass RERA/KYC token. Unset = stub verification (RERA present -> verified).
SUREPASS_API_TOKEN=
# OpenAI key for LLM listing parser. Unset = heuristic parser (regex-based).
OPENAI_API_KEY=
# HMAC secret for auth tokens. Required in production; generate with
# `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
AUTH_SECRET=
